# Database
DATABASE_URL="file:./dev.db"

# JWT Secrets (generate secure random strings for production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Public base URL of this backend (required in production for calendar feed links)
# Set to your deployed API URL so .ics subscription links point to the right host.
# If unset, the URL is inferred from the incoming request (fine for local dev).
# BACKEND_PUBLIC_URL="https://api.yourdomain.com"

# Email transport (console | resend)
# console = log emails to stdout, no account required (default for local dev)
# resend  = send via Resend SDK (required for production)
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@cubscouts.local

# Resend API key — required only when EMAIL_TRANSPORT=resend
# Create an account at https://resend.com, verify your domain, then add the key here.
# RESEND_API_KEY=re_xxxxxxxxxxxx
